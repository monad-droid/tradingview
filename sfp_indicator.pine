//@version=5
indicator("Swing Failure Pattern (SFP)", overlay=true, max_labels_count=500)

// ── Inputs ──────────────────────────────────────────────────
swingLen   = input.int(3,      "Swing Lookback/Lookahead", minval=1, maxval=20)
minWickPct = input.float(0.05, "Min Wick Beyond Swing (%)", minval=0.0, step=0.01)
maxAge     = input.int(500,    "Max Swing Age (bars)",      minval=50, maxval=2000,
             tooltip="Swings older than this are expired.")
showRecent = input.bool(false, "Show Recent Only",
             tooltip="When enabled, only shows SFP markers within the last N bars. Disable to see full history.")
recentBars = input.int(20,    "Recent Bars Count", minval=5, maxval=500)
showBull   = input.bool(true,  "Show Bullish SFPs")
showBear   = input.bool(true,  "Show Bearish SFPs")
bullColor  = input.color(color.new(#00e676, 0), "Bullish Color")
bearColor  = input.color(color.new(#ff1744, 0), "Bearish Color")

maxSwings = 20

// ── Swing Detection ─────────────────────────────────────────
// A swing high is confirmed when bar[swingLen] has the highest high
// within swingLen bars on both sides.
isSwingHigh(idx) =>
    ok = true
    for j = 1 to swingLen
        if high[idx] <= high[idx + j] or high[idx] <= high[idx - j]
            ok := false
            break
    ok

isSwingLow(idx) =>
    ok = true
    for j = 1 to swingLen
        if low[idx] >= low[idx + j] or low[idx] >= low[idx - j]
            ok := false
            break
    ok

// ── Swing Storage ───────────────────────────────────────────
// price, bar_index when swing formed, status (0=active, 1=consumed)
var float[] shPrices = array.new_float(0)
var int[]   shBars   = array.new_int(0)
var int[]   shStatus = array.new_int(0)

var float[] slPrices = array.new_float(0)
var int[]   slBars   = array.new_int(0)
var int[]   slStatus = array.new_int(0)

// ── Register New Swings + Retroactive Gap Check ─────────────
// When a swing is confirmed swingLen bars after formation, the bars
// between formation and confirmation have not been evaluated against
// this swing. We must retroactively check those gap bars (in
// chronological order) for breaks and SFPs to avoid false signals.

if isSwingHigh(swingLen)
    swPrice = high[swingLen]
    consumed = 0
    // Check gap bars in chronological order (oldest to newest)
    // k = swingLen-1 is the bar right after the swing; k = 1 is the most recent
    if swingLen > 1
        for k = swingLen - 1 to 1
            if consumed == 0
                if high[k] > swPrice and close[k] < swPrice
                    wickDepth = high[k] - swPrice
                    if (wickDepth / swPrice) * 100 >= minWickPct
                        consumed := 1
                        gapBarIdx = bar_index - k
                        if showBear and (not showRecent or gapBarIdx >= last_bar_index - recentBars)
                            label.new(gapBarIdx, high[k], "SFP",
                                 color=bearColor, style=label.style_label_down,
                                 textcolor=color.white, size=size.small)
                else if close[k] > swPrice
                    // Bar closed above swing high — swing is broken
                    consumed := 1
    array.unshift(shPrices, swPrice)
    array.unshift(shBars,   bar_index - swingLen)
    array.unshift(shStatus, consumed)
    if array.size(shPrices) > maxSwings
        array.pop(shPrices)
        array.pop(shBars)
        array.pop(shStatus)

if isSwingLow(swingLen)
    swPrice = low[swingLen]
    consumed = 0
    if swingLen > 1
        for k = swingLen - 1 to 1
            if consumed == 0
                if low[k] < swPrice and close[k] > swPrice
                    wickDepth = swPrice - low[k]
                    if (wickDepth / swPrice) * 100 >= minWickPct
                        consumed := 1
                        gapBarIdx = bar_index - k
                        if showBull and (not showRecent or gapBarIdx >= last_bar_index - recentBars)
                            label.new(gapBarIdx, low[k], "SFP",
                                 color=bullColor, style=label.style_label_up,
                                 textcolor=color.white, size=size.small)
                else if close[k] < swPrice
                    // Bar closed below swing low — swing is broken
                    consumed := 1
    array.unshift(slPrices, swPrice)
    array.unshift(slBars,   bar_index - swingLen)
    array.unshift(slStatus, consumed)
    if array.size(slPrices) > maxSwings
        array.pop(slPrices)
        array.pop(slBars)
        array.pop(slStatus)

// ── Expire Old Swings ───────────────────────────────────────
if array.size(shBars) > 0
    for i = array.size(shBars) - 1 to 0
        if bar_index - array.get(shBars, i) > maxAge
            array.set(shStatus, i, 1)

if array.size(slBars) > 0
    for i = array.size(slBars) - 1 to 0
        if bar_index - array.get(slBars, i) > maxAge
            array.set(slStatus, i, 1)

// ── SFP Detection (current bar) ────────────────────────────
// Each bar checks every active swing for SFP or break conditions.
// Swing high → bearish SFP: wick above + close below + wick large enough
// Swing high → broken:      close above (no SFP possible on this swing)
// Swing low  → bullish SFP: wick below + close above + wick large enough
// Swing low  → broken:      close below (no SFP possible on this swing)

bearishSFP = false
bullishSFP = false

// Check swing highs → bearish SFP
if showBear and array.size(shPrices) > 0
    for i = 0 to array.size(shPrices) - 1
        if array.get(shStatus, i) == 0
            swPrice = array.get(shPrices, i)
            if high > swPrice and close < swPrice
                wickDepth = high - swPrice
                if (wickDepth / swPrice) * 100 >= minWickPct
                    bearishSFP := true
                    array.set(shStatus, i, 1)
            else if close > swPrice
                // Closed above swing high — broken, no SFP possible
                array.set(shStatus, i, 1)

// Check swing lows → bullish SFP
if showBull and array.size(slPrices) > 0
    for i = 0 to array.size(slPrices) - 1
        if array.get(slStatus, i) == 0
            swPrice = array.get(slPrices, i)
            if low < swPrice and close > swPrice
                wickDepth = swPrice - low
                if (wickDepth / swPrice) * 100 >= minWickPct
                    bullishSFP := true
                    array.set(slStatus, i, 1)
            else if close < swPrice
                // Closed below swing low — broken, no SFP possible
                array.set(slStatus, i, 1)

// ── Plot ────────────────────────────────────────────────────
inRange = not showRecent or bar_index >= last_bar_index - recentBars

plotshape(bearishSFP and inRange, title="Bearish SFP", style=shape.triangledown,
     location=location.abovebar, color=bearColor, size=size.small, text="SFP")

plotshape(bullishSFP and inRange, title="Bullish SFP", style=shape.triangleup,
     location=location.belowbar, color=bullColor, size=size.small, text="SFP")

// ── Alerts ──────────────────────────────────────────────────
alertcondition(bearishSFP, title="Bearish SFP", message="Bearish SFP — swept swing high")
alertcondition(bullishSFP, title="Bullish SFP", message="Bullish SFP — swept swing low")
